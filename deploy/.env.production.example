# --- GVK backend production .env ---
# KOPIÉR til /opt/gvk/backend/.env og fyll inn ekte verdier.
# chmod 600  /opt/gvk/backend/.env  &&  chown gvk:gvk /opt/gvk/backend/.env

ENVIRONMENT=production

# Generér med:  python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=BYTT_MEG_MIN_48_TILFELDIGE_TEGN_HER

# Generér med:  python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# (brukes til å kryptere Susoft-passord i DB)
ENCRYPTION_KEY=BYTT_MEG_FERNET_NOEKKEL

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# SQLite holder fint i starten – flytt til Postgres når det blir flere tenants.
DATABASE_URL=sqlite:////opt/gvk/backend/gvk.db
# DATABASE_URL=postgresql+psycopg2://gvk:STRONG_PASSWORD@127.0.0.1:5432/gvk

# Cloudflare Tunnel terminerer TLS, så frontend kommer inn på samme origin
# (https://verksted.poshub.no) – ingen CORS nødvendig for prod-deploy via nginx.
# Vi setter likevel allow-listen for sikkerhets skyld:
CORS_ORIGINS=https://verksted.poshub.no
TRUSTED_HOSTS=verksted.poshub.no,localhost,127.0.0.1

UPLOAD_DIR=/opt/gvk/backend/uploads

# --- Seeding første gangen ---
SEED_TENANT_NAME=PosHub Verksted
SEED_TENANT_SLUG=poshub
SEED_ADMIN_EMAIL=admin@poshub.no
SEED_ADMIN_NAME=Admin
SEED_ADMIN_PASSWORD=BYTT_VED_FORSTE_INNLOGGING

# Promotér deg selv til superadmin (e-post må allerede finnes som bruker):
SEED_SUPERADMIN_EMAIL=jon.sigurdarson@advania.no
